{
  "name": "czechibank",
  "version": "0.1.5",
  "private": true,
  "engines": {
    "node": "~20.19.5"
  },
  "scripts": {
    "dev": "npm run db:seed:features && next dev --turbopack",
    "build": "prisma generate && next build",
    "post:build": "mkdir build/standalone/.next && cp -r public build/standalone/ && cp -r .next/static build/standalone/.next/",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "release": "standard-version",
    "db:prepare": "prisma generate & prisma migrate dev",
    "db:ci:setup": "tsx scripts/setup-database.ts",
    "db:seed:users": "tsx scripts/seed-users.ts",
    "db:seed:features": "tsx scripts/seed-features.ts",
    "db:seed:missions": "tsx scripts/seed-missions.ts",
    "deploy:local": "next build && pm2 startOrRestart ecosystem.config.js --env local",
    "deploy:dev": "next build && pm2 startOrRestart ecosystem.config.js --env dev",
    "deploy:prod": "next build && pm2 startOrRestart ecosystem.config.js --env prod",
    "test:performance": "k6 run -e APIKEY=33 tests/performance/script.js ",
    "test:unit": "vitest tests/unit/",
    "test:api": "vitest tests/api/",
    "test:e2e": "bddgen && playwright test"
  },
  "dependencies": {
    "@better-auth/cli": "^1.4.10",
    "@dicebear/collection": "^9.2.4",
    "@dicebear/core": "^9.2.4",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.22.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/uuid": "^10.0.0",
    "better-auth": "^1.4.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "jose": "^5.10.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.522.0",
    "neverthrow": "^8.2.0",
    "next": "15.3.6",
    "next-themes": "^0.2.1",
    "plausible-tracker": "^0.3.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "react-nice-avatar": "^1.5.0",
    "recharts": "^3.5.1",
    "swagger-jsdoc": "^6.2.8",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/lodash": "^4.17.21",
    "@types/node": "^20.19.26",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.2",
    "playwright-bdd": "^8.4.2",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-gherkin": "^3.1.3",
    "prettier-plugin-organize-imports": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "prisma": "^5.22.0",
    "standard-version": "^9.5.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,css,md,tsx,ts}": "npm run format"
  }
}
