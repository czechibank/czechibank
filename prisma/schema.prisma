generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  banExpires    DateTime?
  banReason     String?
  banned        Boolean?
  role          String?
  superTokens   Int           @default(0)
  bankAccounts  BankAccount[]
  accounts      Account[]
  apikeys       Apikey[]
  sessions      Session[]
  missionAchievements UserMissionAchievement[]
  userRewards   UserReward[]

  @@map("user")
}

model BankAccount {
  id              String        @id @default(cuid())
  number          String        @unique
  name            String
  currency        Currency      @default(CZECHITOKEN)
  userId          String
  balance         Float         @default(100000)
  user            User          @relation(fields: [userId], references: [id])
  outTransactions Transaction[] @relation("FromAccount")
  inTransactions  Transaction[] @relation("ToAccount")
}

model Transaction {
  id         String      @id @default(cuid())
  amount     Float
  currency   Currency
  fromBankId String
  toBankId   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  from       BankAccount @relation("FromAccount", fields: [fromBankId], references: [id])
  to         BankAccount @relation("ToAccount", fields: [toBankId], references: [id])
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Apikey {
  id                  String    @id
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?
  rateLimitEnabled    Boolean?
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("apikey")
}

// API Drop Missions Models

model Mission {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // "payload_validation", "rate_limit", "transaction_count", etc.
  status      String   @default("active") // "active", "inactive"
  
  // API endpoint this mission targets
  endpoint    String   // e.g., "/api/v1/transactions/create"
  method      String   // "GET", "POST", "PUT", "DELETE"
  
  // Conditions
  conditions  Json     // { 
                       //   type: "payload_validation",
                       //   requiredFields: ["amount", "toBankNumber"],
                       //   exactValues: { amount: 222 },
                       //   regexPatterns: { vaultName: "Emergency.*" }
                       // }
  
  // Timing (optional)
  timeWindow  Json?    // { startHour: 14, endHour: 14.5, daysOfWeek: [1,2,3,4,5] }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  rewards     MissionReward[]
  achievements UserMissionAchievement[]
  
  @@map("mission")
}

model Reward {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  superTokens Int      @default(0)
  badgeName   String?
  badgeIcon   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  missions    MissionReward[]
  userRewards UserReward[]
  
  @@map("reward")
}

model MissionReward {
  id        String   @id @default(cuid())
  missionId String
  rewardId  String
  
  // Relations
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  reward    Reward   @relation(fields: [rewardId], references: [id])
  
  @@unique([missionId, rewardId])
  @@map("mission_reward")
}

model UserMissionAchievement {
  id        String   @id @default(cuid())
  userId    String
  missionId String
  completedAt DateTime @default(now())
  payload   Json?    // Store the actual API call payload that triggered completion
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, missionId])
  @@map("user_mission_achievement")
}

model UserReward {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  awardedAt DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward    Reward   @relation(fields: [rewardId], references: [id])
  
  @@map("user_reward")
}

enum Currency {
  CZECHITOKEN
  CZK
  USD
}
