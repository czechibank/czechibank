datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl"]
  output        = "../node_modules/.prisma/client"
}

enum Sex {
  MALE
  FEMALE
}

model User {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  bankAccounts  BankAccount[]

  role       String?
  banned     Boolean?
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

enum Currency {
  CZECHITOKEN
  CZK
  USD
}

model BankAccount {
  id              String        @id @default(cuid())
  number          String        @unique
  name            String
  currency        Currency      @default(CZECHITOKEN)
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  // Remove or rename the duplicate Transaction field
  inTransactions  Transaction[] @relation(name: "ToAccount")
  outTransactions Transaction[] @relation(name: "FromAccount")
  balance         Float         @default(100000)
}

model Transaction {
  id         String      @id @default(cuid())
  amount     Float
  currency   Currency
  from       BankAccount @relation(name: "FromAccount", fields: [fromBankId], references: [id])
  fromBankId String
  to         BankAccount @relation(name: "ToAccount", fields: [toBankId], references: [id])
  toBankId   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
